{
  "identifier": "default",
  "description": "Default permissions for GlazeWM Config Editor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-create-dir",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:scope-home-recursive",
    "fs:scope-appdata-recursive",
    "path:default",
    "notification:default"
  ]
}
